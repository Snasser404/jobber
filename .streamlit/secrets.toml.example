# Streamlit Cloud secrets — paste into Settings -> Secrets (with REAL values).

# --- AI engine: keep Claude OR switch to a cheaper/free model ---
ANTHROPIC_API_KEY = "sk-ant-..."

# To use a free/cheap model instead (you can then drop the Claude key), set these:
# LLM_PROVIDER = "openai"
# LLM_BASE_URL = "https://openrouter.ai/api/v1"            # or DeepSeek / Gemini / Groq base URL
# LLM_API_KEY  = "..."
# LLM_MODEL    = "deepseek/deepseek-chat-v3-0324:free"

# --- Job sources ---
ADZUNA_APP_ID  = "your-adzuna-id"
ADZUNA_APP_KEY = "your-adzuna-key"
RAPIDAPI_KEY   = "your-jsearch-rapidapi-key"     # LinkedIn/Indeed/Glassdoor via JSearch

# --- Online access ---
JOBBER_PASSWORD = "choose-a-password"
JOBBER_CLOUD    = "1"
