# Streamlit Cloud secrets — paste these (with REAL values) into your app's
# Settings -> Secrets box on share.streamlit.io.  Do NOT commit real values.

ANTHROPIC_API_KEY = "sk-ant-..."
ADZUNA_APP_ID = "your-adzuna-id"
ADZUNA_APP_KEY = "your-adzuna-key"

# Protects the public link (required online). Pick anything you'll remember.
JOBBER_PASSWORD = "choose-a-password"

# Tells the app it's hosted (turns the password gate on, hides the local-only
# auto-fill browser step). Keep this as "1" on the cloud.
JOBBER_CLOUD = "1"
