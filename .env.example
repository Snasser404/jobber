# ----- Copy this file to ".env" and fill in your keys -----

# REQUIRED: Claude API key (the AI engine).
# Get one at https://console.anthropic.com  ->  Settings -> API Keys
ANTHROPIC_API_KEY=

# OPTIONAL: Adzuna job API (free). Adds lots of Canadian listings.
# Sign up at https://developer.adzuna.com  -> create an app -> copy the IDs.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Access password — required only if you share the app online (serve_online.ps1).
# Leave blank for local-only use.
JOBBER_PASSWORD=
