# ===== Copy this file to ".env" and fill in what you need =====

# ---------- AI engine (pick ONE) ----------
# Option A (default): Claude — best quality.  https://console.anthropic.com
ANTHROPIC_API_KEY=

# Option B: a cheaper/FREE model via any OpenAI-compatible provider.
# Just setting LLM_API_KEY switches the engine to it. Uncomment ONE block:

# OpenRouter — FREE DeepSeek/Qwen/Llama, one key for many models.  https://openrouter.ai/keys
#LLM_PROVIDER=openai
#LLM_BASE_URL=https://openrouter.ai/api/v1
#LLM_API_KEY=
#LLM_MODEL=deepseek/deepseek-chat-v3-0324:free

# DeepSeek (direct) — Chinese, very cheap, production-grade.  https://platform.deepseek.com
#LLM_PROVIDER=openai
#LLM_BASE_URL=https://api.deepseek.com
#LLM_API_KEY=
#LLM_MODEL=deepseek-chat

# Google Gemini — generous free tier.  https://aistudio.google.com/apikey
#LLM_PROVIDER=openai
#LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#LLM_API_KEY=
#LLM_MODEL=gemini-2.0-flash

# Groq — free + very fast.  https://console.groq.com/keys
#LLM_PROVIDER=openai
#LLM_BASE_URL=https://api.groq.com/openai/v1
#LLM_API_KEY=
#LLM_MODEL=llama-3.3-70b-versatile

# (Optional) use a smaller/cheaper model just for ranking many jobs:
#LLM_RANK_MODEL=

# ---------- Job sources ----------
# Adzuna (free) — lots of Canadian listings.  https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# JSearch (free tier) — LinkedIn / Indeed / Glassdoor / Talent.com via Google for Jobs.
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch  (copy your X-RapidAPI-Key)
RAPIDAPI_KEY=

# ---------- Sharing online ----------
# Access password (required only when shared online via serve_online.ps1 or the cloud).
JOBBER_PASSWORD=
